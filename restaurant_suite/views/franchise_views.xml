<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_franchise_tree" model="ir.ui.view">
        <field name="name">restaurant.franchise.tree</field>
        <field name="model">restaurant.franchise</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="hq_company_id"/>
                <field name="royalty_rate"/>
                <field name="royalty_base"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_franchise_form" model="ir.ui.view">
        <field name="name">restaurant.franchise.form</field>
        <field name="model">restaurant.franchise</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Generate Royalty Invoice" type="action" name="%(action_royalty_invoice_wizard)d" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id"/>
                            <field name="hq_company_id"/>
                            <field name="hq_partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="royalty_rate"/>
                            <field name="royalty_base"/>
                            <field name="royalty_account_id"/>
                            <field name="royalty_journal_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_restaurant_franchise" model="ir.actions.act_window">
        <field name="name">Franchises</field>
        <field name="res_model">restaurant.franchise</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
