<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_allergen_tree" model="ir.ui.view">
        <field name="name">restaurant.allergen.tree</field>
        <field name="model">restaurant.allergen</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_allergen_form" model="ir.ui.view">
        <field name="name">restaurant.allergen.form</field>
        <field name="model">restaurant.allergen</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="icon" widget="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_allergen" model="ir.actions.act_window">
        <field name="name">Allergens</field>
        <field name="res_model">restaurant.allergen</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_restaurant_scrap_reason_tree" model="ir.ui.view">
        <field name="name">restaurant.scrap.reason.tree</field>
        <field name="model">restaurant.scrap.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_scrap_reason_form" model="ir.ui.view">
        <field name="name">restaurant.scrap.reason.form</field>
        <field name="model">restaurant.scrap.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_scrap_reason" model="ir.actions.act_window">
        <field name="name">Waste Reasons</field>
        <field name="res_model">restaurant.scrap.reason</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
