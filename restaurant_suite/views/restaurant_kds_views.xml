<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_kds_station_tree" model="ir.ui.view">
        <field name="name">restaurant.kds.station.tree</field>
        <field name="model">restaurant.kds.station</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="pos_config_id"/>
                <field name="display_mode"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_kds_station_form" model="ir.ui.view">
        <field name="name">restaurant.kds.station.form</field>
        <field name="model">restaurant.kds.station</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="pos_config_id"/>
                        <field name="pos_category_ids" widget="many2many_tags"/>
                        <field name="display_mode"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_restaurant_kds_order_tree" model="ir.ui.view">
        <field name="name">restaurant.kds.order.tree</field>
        <field name="model">restaurant.kds.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="pos_order_id"/>
                <field name="table_id"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="station_id"/>
                <field name="kitchen_status"/>
                <field name="sent_at"/>
            </list>
        </field>
    </record>

    <record id="action_restaurant_kds_station" model="ir.actions.act_window">
        <field name="name">KDS Stations</field>
        <field name="res_model">restaurant.kds.station</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_restaurant_kds_order" model="ir.actions.act_window">
        <field name="name">KDS Orders</field>
        <field name="res_model">restaurant.kds.order</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_restaurant_kds_backend" model="ir.actions.client">
        <field name="name">Kitchen Display</field>
        <field name="tag">restaurant_suite.kds_backend</field>
        <field name="context">{'stationId': False}</field>
    </record>
</odoo>
