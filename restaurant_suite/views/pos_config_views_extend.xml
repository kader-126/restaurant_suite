<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_restaurant_suite" model="ir.ui.view">
        <field name="name">pos.config.form.restaurant.suite</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert a page when the parent view uses a notebook -->
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Restaurant Suite">
                    <group>
                        <field name="franchise_id"/>
                        <field name="kds_station_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="display_mode"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

            <!-- If the parent view has no notebook, insert the same fields directly into the sheet -->
            <xpath expr="//sheet[not(descendant::notebook)]" position="inside">
                <group>
                    <group>
                        <field name="franchise_id"/>
                        <field name="kds_station_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="display_mode"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
