<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_royalty_invoice_wizard_form" model="ir.ui.view">
        <field name="name">restaurant.royalty.invoice.wizard.form</field>
        <field name="model">restaurant.royalty.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Royalty Invoice">
                <group>
                    <field name="franchise_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_generate_invoice" type="object" string="Generate" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_royalty_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Generate Royalty Invoice</field>
        <field name="res_model">restaurant.royalty.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
